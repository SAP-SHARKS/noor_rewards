# Placeholder .env shipped with the repo so the Flutter asset bundler always
# finds the file. Real values are injected by CI (Codemagic env vars) or by
# local developers. Leave these blank in the tracked copy — never paste real
# secrets here.
#
# Local devs: after pasting your real values, run:
#   git update-index --skip-worktree .env
# so your edits stop showing in `git status`.

IS_DEV=true
QURAN_PRELIVE_CLIENT_ID=
QURAN_PRELIVE_CLIENT_SECRET=
QURAN_PROD_CLIENT_ID=
QURAN_PROD_CLIENT_SECRET=
