# Placeholder .env committed so Codemagic / CI builds find the file
# declared in pubspec.yaml's assets section. Real values live outside git:
#   - Locally: set via your own .env (skip-worktree on this file — see README)
#   - CI: inject as Codemagic environment variables and overwrite this file
#     in a pre-build script if/when you want auth to work in CI
#
# All values intentionally empty — the Quran API code falls back to
# unauthenticated mode (see lib/services/quran_api_service.dart:71).
IS_DEV=false
QURAN_PRELIVE_CLIENT_ID=
QURAN_PRELIVE_CLIENT_SECRET=
QURAN_PROD_CLIENT_ID=
QURAN_PROD_CLIENT_SECRET=
