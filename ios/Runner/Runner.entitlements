<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- "production" matches the App Store distribution profile fetched
	     by Codemagic from App Store Connect. For local development you
	     might switch this to "development" inside a per-config file, but
	     TestFlight + App Store builds both use the production APNs
	     environment. -->
	<key>aps-environment</key>
	<string>production</string>
</dict>
</plist>
